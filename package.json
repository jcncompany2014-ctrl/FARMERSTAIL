{
  "name": "farmerstail-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:clean": "taskkill /F /IM node.exe 2>nul & next dev",
    "dev": "next dev",
    "prebuild": "node scripts/inject-build-sha.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:design": "node scripts/check-design-scale.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "verify": "npx eslint . && npx tsc --noEmit && npm test",
    "build:ci": "node scripts/ci-build.mjs",
    "verify:push": "npm run verify && npm run build:ci",
    "test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test \"lib/**/*.test.ts\"",
    "test:watch": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test --watch \"lib/**/*.test.ts\"",
    "test:coverage": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout \"lib/**/*.test.ts\"",
    "precommit": "npx eslint --max-warnings 100 . && npx tsc --noEmit",
    "tsc:strict": "npx tsc --noEmit --project tsconfig.strict.json",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:install": "npx playwright install --with-deps chromium webkit",
    "install:hooks": "node scripts/install-git-hooks.mjs",
    "newsletter:vol-01:dry": "node --env-file-if-exists=.env.local --experimental-strip-types --disable-warning=ExperimentalWarning scripts/send-newsletter-vol-01.ts --dry-run",
    "newsletter:vol-01:test": "node --env-file-if-exists=.env.local --experimental-strip-types --disable-warning=ExperimentalWarning scripts/send-newsletter-vol-01.ts --test",
    "newsletter:vol-01:send": "node --env-file-if-exists=.env.local --experimental-strip-types --disable-warning=ExperimentalWarning scripts/send-newsletter-vol-01.ts",
    "analyze": "ANALYZE=true next build",
    "analyze:win": "powershell -Command \"$env:ANALYZE='true'; next build\"",
    "cap:webdir": "node -e \"require('fs').mkdirSync('capacitor-web',{recursive:true});require('fs').writeFileSync('capacitor-web/index.html','<!doctype html><meta charset=\\\"utf-8\\\"><title>Farmer\\u0027s Tail</title>')\"",
    "cap:add:android": "npm run cap:webdir && npx cap add android",
    "cap:add:ios": "npm run cap:webdir && npx cap add ios",
    "cap:sync": "npm run cap:webdir && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:dev:android": "powershell -Command \"$env:CAPACITOR_SERVER_URL='http://10.0.2.2:3000'; npx cap sync android; npx cap run android\"",
    "cap:dev:ios": "CAPACITOR_SERVER_URL=http://localhost:3000 npx cap sync ios && npx cap run ios",
    "cap:assets": "npx -p @capacitor/assets@latest cap-assets generate --iconBackgroundColor '#F5F0E6' --iconBackgroundColorDark '#171310' --splashBackgroundColor '#F5F0E6' --splashBackgroundColorDark '#171310'"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.103.0",
    "@tosspayments/tosspayments-sdk": "^2.7.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "pretendard": "^1.3.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "recharts": "^3.8.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@^4.60.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.49.0",
    "@storybook/nextjs-vite": "^10.4.2",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "storybook": "^10.4.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.16"
  }
}
