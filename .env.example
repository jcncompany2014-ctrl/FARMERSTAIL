# Farmer's Tail — environment variables (.env.local 템플릿).
#
# 이 파일은 git 에 커밋된다 (값은 비어있음).
# 실 키는 .env.local 에 채우거나 Vercel Project Settings → Environment Variables
# 에 등록. NEXT_PUBLIC_ 접두사는 클라이언트 번들에 노출되니 주의.
#
# 자세한 검증 스키마: lib/env.ts (server) + lib/env.client.ts (client).
# 누락 시 부팅 실패 / silent skip 동작은 LAUNCH_CHECKLIST.md 참조.

# ──────────────────────────────────────────────────────────────────────────
# 🔴 필수 — 누락 시 부팅 실패
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://farmerstail.com

# ──────────────────────────────────────────────────────────────────────────
# 🟡 결제 (Toss) — 누락 시 결제 503
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Toss 위젯 v2 사용 시 별도 client key
NEXT_PUBLIC_TOSS_WIDGET_CLIENT_KEY=

# ──────────────────────────────────────────────────────────────────────────
# 🟡 메일 (Resend) — 누락 시 거래메일 모두 silent skip
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="파머스테일 <no-reply@farmerstail.com>"
EMAIL_REPLY_TO=

# ──────────────────────────────────────────────────────────────────────────
# 🟡 모니터링 (Sentry) — 누락 시 에러 트래킹 안 됨
# ──────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# 🟡 AI 분석 (Anthropic) — 누락 시 분석 503
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 분석 / 광고 — 없으면 GA/Pixel 미전송 (앱은 정상)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 푸시 알림 (Web Push) — 3종 모두 있어야 활성
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@farmerstail.com

# ──────────────────────────────────────────────────────────────────────────
# 🟢 Vercel Cron 보호
# ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 사업자 정보 (전자상거래법 §10)
# 비어있으면 lib/business.ts 의 const 값이 사용됨 (현재 사용 패턴).
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_COMPANY_NAME=
NEXT_PUBLIC_BUSINESS_CEO=
NEXT_PUBLIC_BUSINESS_NUMBER=
NEXT_PUBLIC_BUSINESS_MAIL_ORDER_NUMBER=
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=
NEXT_PUBLIC_BUSINESS_PRIVACY_OFFICER=
NEXT_PUBLIC_BUSINESS_PRIVACY_OFFICER_EMAIL=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 카카오 채널 (선택)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_CHANNEL_URL=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 Capacitor (네이티브 앱)
# ──────────────────────────────────────────────────────────────────────────
# 앱이 로드할 도메인 — 미설정 시 capacitor.config.ts 의 default 사용.
CAPACITOR_SERVER_URL=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 Universal Links / App Links
# ──────────────────────────────────────────────────────────────────────────
# Apple Developer Portal → Membership → Team ID (10자).
APPLE_APP_SITE_TEAM_ID=
# Android Play Console 앱 서명 SHA-256 (콜론 형식, 콤마 구분 가능).
ANDROID_PACKAGE_NAME=com.farmerstail.app
ANDROID_FINGERPRINTS=
