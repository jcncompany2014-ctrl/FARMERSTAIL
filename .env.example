# Farmer's Tail — environment variables (.env.local 템플릿).
#
# 이 파일은 git 에 커밋된다 (값은 비어있음).
# 실 키는 .env.local 에 채우거나 Vercel Project Settings → Environment Variables
# 에 등록. NEXT_PUBLIC_ 접두사는 클라이언트 번들에 노출되니 주의.
#
# 자세한 검증 스키마: lib/env.ts (server) + lib/env.client.ts (client).
# 누락 시 부팅 실패 / silent skip 동작은 LAUNCH_CHECKLIST.md 참조.

# ──────────────────────────────────────────────────────────────────────────
# 🔴 필수 — 누락 시 부팅 실패
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://www.farmerstail.kr

# ──────────────────────────────────────────────────────────────────────────
# 🟡 결제 (Toss) — 누락 시 결제 503
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Toss 위젯 v2 사용 시 별도 client key
NEXT_PUBLIC_TOSS_WIDGET_CLIENT_KEY=

# ──────────────────────────────────────────────────────────────────────────
# 🟡 메일 (Resend) — 누락 시 거래메일 모두 silent skip
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="파머스테일 <no-reply@farmerstail.kr>"
EMAIL_REPLY_TO=
# Resend webhook 서명 검증 — production 필수 (`whsec_...`).
# 미설정 시 svix 서명 검증이 우회되어 webhook 위조 가능. dev 에서만 미설정 허용.
RESEND_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# 🟡 모니터링 (Sentry) — 누락 시 에러 트래킹 안 됨
# ──────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# 🟡 AI 분석 (Anthropic) — 누락 시 분석 503
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 분석 / 광고 — 없으면 GA/Pixel 미전송 (앱은 정상)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# Microsoft Clarity — 세션 리플레이 / heatmap (선택)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 푸시 알림 (Web Push) — 3종 모두 있어야 활성
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:story@farmerstail.kr

# ──────────────────────────────────────────────────────────────────────────
# 🟢 네이티브 푸시 (APNs / FCM) — Capacitor 앱 출시 후
# ──────────────────────────────────────────────────────────────────────────
# Apple Push Notification service — .p8 key 기반 인증
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=com.farmerstail.app
# Sandbox / production 환경 분기 ('1' = sandbox / dev)
APNS_USE_SANDBOX=
# Firebase Cloud Messaging — service account 기반
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
FCM_PROJECT_ID=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 Vercel Cron 보호
# ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 사업자 정보 (전자상거래법 §10)
# 비어있으면 lib/business.ts 의 const 값이 사용됨 (현재 사용 패턴).
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_COMPANY_NAME=
NEXT_PUBLIC_BUSINESS_CEO=
NEXT_PUBLIC_BUSINESS_NUMBER=
NEXT_PUBLIC_BUSINESS_MAIL_ORDER_NUMBER=
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=
NEXT_PUBLIC_BUSINESS_PRIVACY_OFFICER=
NEXT_PUBLIC_BUSINESS_PRIVACY_OFFICER_EMAIL=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 카카오 채널 (선택)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_CHANNEL_URL=
# 카카오 공유 SDK — 카톡 share card 렌더에 필요
NEXT_PUBLIC_KAKAO_JS_KEY=
# 통신판매업 신고번호 override (운영 출시 후 등록 시)
NEXT_PUBLIC_MAIL_ORDER_NUMBER=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 통합 (Integrations) — Tractive GPS 트래커 OAuth
# ──────────────────────────────────────────────────────────────────────────
TRACTIVE_CLIENT_ID=
TRACTIVE_CLIENT_SECRET=
TRACTIVE_OAUTH_REDIRECT_URI=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 환영 쿠폰 (선택) — 첫 구독 인입 코드
# ──────────────────────────────────────────────────────────────────────────
WELCOME_COUPON_CODE=
NEXT_PUBLIC_WELCOME_COUPON_CODE=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 UI feature flags (선택) — 'on' 으로 설정 시 활성
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SHOW_ADVANCED_INPUTS=
NEXT_PUBLIC_SHOW_PHOTO_REQUEST=
NEXT_PUBLIC_SHOW_OCR=
NEXT_PUBLIC_SHOW_PHOTO_TIPS=
# Sign in with Apple 임시 비활성 ('1' = 숨김)
NEXT_PUBLIC_DISABLE_SIWA=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 Capacitor (네이티브 앱)
# ──────────────────────────────────────────────────────────────────────────
# 앱이 로드할 도메인 — 미설정 시 capacitor.config.ts 의 default 사용.
CAPACITOR_SERVER_URL=

# ──────────────────────────────────────────────────────────────────────────
# 🟢 Universal Links / App Links
# ──────────────────────────────────────────────────────────────────────────
# Apple Developer Portal → Membership → Team ID (10자).
APPLE_APP_SITE_TEAM_ID=
# Android Play Console 앱 서명 SHA-256 (콜론 형식, 콤마 구분 가능).
ANDROID_PACKAGE_NAME=com.farmerstail.app
ANDROID_FINGERPRINTS=

# ─────────────────────────────────────────────────────────────────────────────
# 발명 핵심 알고리즘 feature flag (PCT 출원 전 kill switch)
# default 모두 OFF. 'on' 으로 설정해야 동작. 끄면 자동 비활성.
# ─────────────────────────────────────────────────────────────────────────────
# 전체 master switch — OFF 면 sub 모두 자동 OFF
NEXT_PUBLIC_INVENTION_CORE=off
# 모듈 H 메타학습 가중치 갱신 cron + algorithm_meta_weights
NEXT_PUBLIC_INVENTION_META_LEARNING=on
# 모듈 G 반사실 sensitivity analysis (Pearl framework)
NEXT_PUBLIC_INVENTION_COUNTERFACTUAL=on
# 4 페르소나 클러스터링 (data_lover/emotional/convenience/vet_dependent)
NEXT_PUBLIC_INVENTION_PERSONA=on
# 모듈 B W_image 산출 (촬영 각도/자세/털 길이 가중치)
NEXT_PUBLIC_INVENTION_W_IMAGE=on
